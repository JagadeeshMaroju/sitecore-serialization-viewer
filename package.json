{
  "name": "sitecore-serialization-viewer",
  "displayName": "Sitecore Serialization Viewer",
  "description": "Visualize Sitecore CLI serialization changes with detailed field-level diffs",
  "version": "1.0.8",
  "publisher": "JagadheeshMaroju",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "sitecore",
    "serialization",
    "yaml",
    "diff",
    "xm-cloud"
  ],
  "activationEvents": [
    "workspaceContains:**/*.module.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sitecoreSerializer.connect",
        "title": "Connect to Sitecore",
        "category": "Sitecore",
        "icon": "$(plug)"
      },
      {
        "command": "sitecoreSerializer.viewChanges",
        "title": "View Serialization Changes",
        "category": "Sitecore",
        "icon": "$(diff)"
      },
      {
        "command": "sitecoreSerializer.previewPull",
        "title": "Preview Pull Changes",
        "category": "Sitecore",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sitecoreSerializer.previewPush",
        "title": "Preview Push Changes",
        "category": "Sitecore",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "sitecoreSerializer.refreshView",
        "title": "Refresh Serialization View",
        "category": "Sitecore",
        "icon": "$(refresh)"
      },
      {
        "command": "sitecoreSerializer.validate",
        "title": "Validate Serialization",
        "category": "Sitecore",
        "icon": "$(check-all)"
      },
      {
        "command": "sitecoreSerializer.validateFix",
        "title": "Fix Validation Errors",
        "category": "Sitecore",
        "icon": "$(wrench)"
      },
      {
        "command": "sitecoreSerializer.executePull",
        "title": "Pull Now",
        "category": "Sitecore",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sitecoreSerializer.executePush",
        "title": "Push Now",
        "category": "Sitecore",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "sitecoreSerializer.showItemDetails",
        "title": "Show Item Details",
        "category": "Sitecore"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sitecore-serialization",
          "title": "Sitecore Serialization",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "sitecore-serialization": [
        {
          "type": "webview",
          "id": "sitecoreConnectionView",
          "name": "Connection",
          "icon": "$(plug)"
        },
        {
          "id": "sitecoreChangesView",
          "name": "Changes Overview",
          "icon": "$(diff)",
          "contextualTitle": "Sitecore Serialization"
        },
        {
          "id": "sitecoreStatsView",
          "name": "Statistics",
          "icon": "$(graph)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sitecoreSerializer.connect",
          "when": "view == sitecoreConnectionView",
          "group": "navigation"
        },
        {
          "command": "sitecoreSerializer.executePull",
          "when": "view == sitecoreChangesView && sitecoreSerializer.previewMode == 'pull'",
          "group": "navigation@1"
        },
        {
          "command": "sitecoreSerializer.executePush",
          "when": "view == sitecoreChangesView && sitecoreSerializer.previewMode == 'push'",
          "group": "navigation@1"
        },
        {
          "command": "sitecoreSerializer.validateFix",
          "when": "view == sitecoreChangesView && sitecoreSerializer.previewMode == 'validate-errors'",
          "group": "navigation@1"
        },
        {
          "command": "sitecoreSerializer.refreshView",
          "when": "view == sitecoreChangesView",
          "group": "navigation@2"
        },
        {
          "command": "sitecoreSerializer.validate",
          "when": "view == sitecoreChangesView",
          "group": "navigation@3"
        },
        {
          "command": "sitecoreSerializer.previewPull",
          "when": "view == sitecoreChangesView",
          "group": "navigation@4"
        },
        {
          "command": "sitecoreSerializer.previewPush",
          "when": "view == sitecoreChangesView",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "sitecoreSerializer.showItemDetails",
          "when": "view == sitecoreChangesView && viewItem == sitecoreItem"
        }
      ]
    },
    "configuration": {
      "title": "Sitecore Serialization Viewer",
      "properties": {
        "sitecoreSerializer.loginType": {
          "type": "string",
          "enum": ["identity", "cloud"],
          "default": "identity",
          "description": "Login method: 'identity' uses Sitecore Identity Server, 'cloud' uses dotnet sitecore cloud login."
        },
        "sitecoreSerializer.sitecoreHost": {
          "type": "string",
          "default": "",
          "description": "Sitecore CM host URL (e.g. https://cm.your-site.com). Used for CLI authentication."
        },
        "sitecoreSerializer.sitecoreAuthority": {
          "type": "string",
          "default": "",
          "description": "Sitecore Identity Server / authority URL. Defaults to the CM host when blank."
        },
        "sitecoreSerializer.serializationPath": {
          "type": "string",
          "default": "Serialization",
          "description": "Path to the Sitecore serialization folder"
        },
        "sitecoreSerializer.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh when serialization files change"
        },
        "sitecoreSerializer.showFieldIDs": {
          "type": "boolean",
          "default": false,
          "description": "Show field IDs in addition to field names"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/yaml": "^1.9.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2",
    "@vscode/vsce": "^2.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JagadeeshMaroju/sitecore-serialization-viewer.git"
  },
  "dependencies": {
    "yaml": "^2.3.4",
    "simple-git": "^3.22.0"
  }
}
